// Fast-path boundary: x[3] == y[3] == mod[3] != 0, x > mod, y > mod.
// Forces normalize-subtract on both operands before sum.
// mod = 2^192 + 5; x = mod + 1 = 2^192 + 6; y = mod + 2 = 2^192 + 7
// (x + y) % mod = ((2^192 + 6) + (2^192 + 7)) % (2^192 + 5)
//               = (2^193 + 13) % (2^192 + 5)
//               = 3 (after normalize: x'=1, y'=2, sum=3 < mod)
PUSH32 0x0000000000000001000000000000000000000000000000000000000000000005
PUSH32 0x0000000000000001000000000000000000000000000000000000000000000007
PUSH32 0x0000000000000001000000000000000000000000000000000000000000000006
ADDMOD
PUSH1 0x00
MSTORE
PUSH1 0x20
PUSH1 0x00
RETURN
